{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/window"],
    "modules-center": ["custom/music"],
    "modules-right": ["tray", "idle_inhibitor", "custom/recording", "privacy", "clock", "pulseaudio", "temperature"],
    "custom/os-logo": {
        "format": "пЊѓ"
    },
    "sway/workspaces": {
         "disable-scroll": true,
         "sort-by-name": true,
         "format": " {icon} ",
	 // "all-outputs": true,
         "format-icons": {
             "default": "о®ґ ",
         }
	 /*"persistent-workspaces": {
	     "*": [ 1, 2, 3, 4, 5 ]
	 },*/
     },
     "sway/window": {
         "format": "{title}",
	 "icon": true,
	 // "seperate-outputs": true,
	 /*"rewrite" : {
	     "Alacritty": "Alacritty",
	     "chromium": "Chromium",
	     "discord": "Discord",
	     "steam": "Steam",
	     "mullvad": "Mullvad",
	     "spotify": "Spotify",
	     "firefox": "Firefox",
	     "gcr-prompter": "Keyring",
	     "XIVLauncher.core": "XIVLauncher",
	     "ffxiv_dx11.exe": "Final Fantasy XIV"
	 }*/
     },
     "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пЃ®",
            "deactivated": "пЃ°"
        },
    },
    "privacy": {
        "icon-spacing": 4,
	"icon-size": 18,
	"transition-duration": 250,
        "modules": [
           {
                "type": "screenshare",
                "tooltip": true,
                "tooltip-icon-size": 24
	    },
        ]
    },
    "custom/recording": {
        "format": "{}",
	"return-type": "json",
	"exec": "$HOME/.config/waybar/scripts/recording.sh status", 
	"tooltip": true,
	"signal": 20,
	"restart-interval": 1,
	"on-click": "$HOME/.config/waybar/scripts/recording.sh toggle"
    },
    "cpu": {
        "format": "{usage}% п‹›",
        "tooltip": false 
    },
    "temperature" : {
        "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
	"input-filename": "temp1_input",
        "critical-threshold": 80,
	"format": "п‹‰ {temperatureC}В°C",
	"interval": 5,
	"tooltip": false
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "custom/music": {
        "format": "рџЋ§  {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ title }}'",
        "on-click": "playerctl play-pause",
	"on-scroll-up": "payerctl previous",
	"on-scroll-down": "playerctl next",
        "max-length": 50
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "у°Ёі {:%a, %b %d (%R)}",
	"locale": "en_GB.UTF-8",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "month",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click-right": "mode",
            "on-scroll-up": "tz_up",
            "on-scroll-down": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    /*"clock#date": {
    },*/
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "п–ѓ",
        "format-plugged": "п–ѓ",
        "format-alt": "{icon}",
        "format-icons": ["п–‚", "п•№",  "п•є", "п•»", "п•ј", "п•Ѕ", "п•Ѕ", "п•ѕ", "п•ї", "п–Ђ", "п–Ѓ", "п•ё"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}{volume}%",
        "format-muted": "п‘¦",
        "format-icons": {
            "default": ["пЂ¦ ", "пЂ§ ", "пЂЁ  "]
        },
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "hyprlock",
        "format": "пЂЈ",
    },
    "custom/power": {
        "tooltip": false,
        "on-click": "wlogout &",
        "format": "пЂ‘ "
    }
}
